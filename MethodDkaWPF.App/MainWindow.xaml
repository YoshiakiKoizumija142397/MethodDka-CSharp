<Window x:Class="MethodDkaWPFApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MethodDka" Height="550" Width="420">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- 最高次数 -->
            <TextBlock Text="最高次数:" FontSize="16"/>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="DegreeBox" Width="80" Margin="0,0,10,0"/>
                <Button Content="最高次数を設定"
                        Style="{StaticResource BlueButton}"
                        Click="SetDegree_Click"/>
            </StackPanel>

            <!-- 自動生成される係数欄 -->
            <StackPanel x:Name="CoefficientPanel" Margin="0,20,0,20"/>

            <!-- 計算開始 -->
            <Button Content="計算開始"
                    Style="{StaticResource BlueButton}"
                    Click="Calculate_Click"/>

            <!-- 結果表示 -->
            <TextBlock Text="計算結果:" FontSize="16" Margin="0,20,0,5"/>
            <TextBlock x:Name="ResultBlock" FontSize="14" TextWrapping="Wrap"/>

        </StackPanel>
    </ScrollViewer>
</Window>
