<Window x:Class="MethodDkaWPFApp.Views.CalculatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MethodDka (50桁版)"
        Width="600" Height="750"
        WindowStartupLocation="CenterScreen"
        Background="#f9f9f9">

	<ScrollViewer VerticalScrollBarVisibility="Auto">
		<StackPanel Margin="20">

			<!-- タイトル -->
			<TextBlock Text="MethodDka (50桁版)"
                       FontSize="26"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

			<!-- 最高次数 -->
			<StackPanel Margin="0,0,0,10">
				<TextBlock Text="最高次数:" FontSize="16"/>
				<TextBox Text="{Binding Degree}"
                         FontSize="16"
                         Padding="6"/>
			</StackPanel>

			<!-- 最高次数を設定 -->
			<Button Content="最高次数を設定"
                    Command="{Binding CreateFieldsCommand}"
                    Background="#007bff"
                    Foreground="White"
                    Padding="10"
                    FontSize="16"
                    Margin="0,0,0,10"
                    BorderThickness="0"
                    Cursor="Hand"/>

			<!-- 係数入力フィールド -->
			<ItemsControl ItemsSource="{Binding CoefficientFields}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<StackPanel Margin="0,0,0,10">
							<TextBlock Text="{Binding Label}" FontSize="15"/>
							<TextBox Text="{Binding Value}"
                                     FontSize="15"
                                     Padding="6"/>
						</StackPanel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- 計算開始 -->
			<Button Content="計算開始"
                    Command="{Binding CalculateCommand}"
                    Background="#007bff"
                    Foreground="White"
                    Padding="10"
                    FontSize="16"
                    Margin="0,10,0,10"
                    BorderThickness="0"
                    Cursor="Hand"/>

			<!-- 結果 -->
			<TextBlock Text="結果:"
                       FontWeight="Bold"
                       FontSize="18"
                       Margin="0,10,0,5"/>

			<TextBox Text="{Binding ResultText}"
                     Background="#e9ecef"
                     Padding="10"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="15"
                     Height="260"/>
		</StackPanel>
	</ScrollViewer>
</Window>